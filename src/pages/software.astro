---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const software = (await getCollection("software")).sort(
  (a, b) => (b.data.priority ?? 0) - (a.data.priority ?? 0)
);
---

<BaseLayout title="Software">
  <div class="prose">
    <h1>Software</h1>

    <p>
      Open-source tools, libraries, and applications I've developed or contributed to.
    </p>

    {software.length === 0 ? (
      <p class="text-gray-500 italic mt-8">
        Software listings coming soon.
      </p>
    ) : (
      <div class="grid gap-6 mt-8">
        {software.map((item) => (
          <article class="border border-gray-200 rounded-lg overflow-hidden hover:border-gray-300 transition-colors">
            {/* Thumbnail or Video */}
            {(item.data.thumbnail || item.data.video) && (
              <div class="relative bg-gray-100">
                {item.data.video ? (
                  <div class="aspect-video">
                    {item.data.video.includes("youtube.com") || item.data.video.includes("youtu.be") ? (
                      <iframe
                        src={item.data.video.replace("watch?v=", "embed/").replace("youtu.be/", "youtube.com/embed/")}
                        class="w-full h-full"
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen
                      />
                    ) : (
                      <video src={item.data.video} class="w-full h-full object-cover" controls preload="metadata" />
                    )}
                  </div>
                ) : item.data.thumbnail && (
                  <Image src={item.data.thumbnail} alt={`${item.data.title}`} class="w-full h-48 object-cover" />
                )}
              </div>
            )}
            <div class="p-5">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-1">
                  <h2 class="text-lg font-medium text-gray-900 mt-0 mb-0">
                    {item.data.url ? (
                      <a href={item.data.url} target="_blank" rel="noopener" class="hover:text-blue-600">
                        {item.data.title}
                      </a>
                    ) : item.data.github ? (
                      <a href={item.data.github} target="_blank" rel="noopener" class="hover:text-blue-600">
                        {item.data.title}
                      </a>
                    ) : (
                      item.data.title
                    )}
                  </h2>
                  {item.data.language && (
                    <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded font-mono">
                      {item.data.language}
                    </span>
                  )}
                </div>
                {item.data.description && (
                  <p class="text-gray-600 text-sm mb-3">{item.data.description}</p>
                )}
                {item.data.tags && item.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {item.data.tags.map((tag) => (
                      <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
              <div class="flex gap-2 flex-shrink-0">
                {item.data.github && (
                  <a
                    href={item.data.github}
                    target="_blank"
                    rel="noopener"
                    class="text-gray-400 hover:text-gray-600"
                    title="View on GitHub"
                  >
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                  </a>
                )}
                {item.data.docs && (
                  <a
                    href={item.data.docs}
                    target="_blank"
                    rel="noopener"
                    class="text-gray-400 hover:text-gray-600"
                    title="Documentation"
                  >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                    </svg>
                  </a>
                )}
                {item.data.pypi && (
                  <a
                    href={item.data.pypi}
                    target="_blank"
                    rel="noopener"
                    class="text-gray-400 hover:text-gray-600"
                    title="PyPI"
                  >
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 0L1.5 6v12L12 24l10.5-6V6L12 0zm0 2.25l7.5 4.5v9l-7.5 4.5-7.5-4.5v-9l7.5-4.5z"/>
                    </svg>
                  </a>
                )}
              </div>
            </div>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
