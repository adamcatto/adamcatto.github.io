---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CommitHistory from "../../components/CommitHistory.astro";
import { getCollection, render } from "astro:content";
import { getFileCommitHistory } from "../../lib/github";

export async function getStaticPaths() {
  const writing = await getCollection("writing");
  return writing.map((piece) => {
    const slug = piece.id.replace(/\/index$/, "");
    return {
      params: { slug },
      props: { piece },
    };
  });
}

const { piece } = Astro.props;
const { Content } = await render(piece);

const folderName = piece.id.replace(/\/index$/, "");
const filePath = `src/content/writing/${folderName}/index.md`;
const commits = await getFileCommitHistory(filePath);

const categoryColors: Record<string, string> = {
  essays: "bg-blue-100 text-blue-700",
  fiction: "bg-purple-100 text-purple-700",
  reviews: "bg-green-100 text-green-700",
  notes: "bg-yellow-100 text-yellow-700",
  tutorials: "bg-orange-100 text-orange-700",
};
---

<BaseLayout title={piece.data.title} description={piece.data.description}>
  <article class="prose">
    <header class="mb-8 not-prose">
      <h1 class="mb-2">{piece.data.title}</h1>
      <div class="flex items-center gap-4 text-sm text-gray-500">
        <time datetime={piece.data.date.toISOString()}>
          {piece.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
        {piece.data.updated && (
          <span>
            Updated: {piece.data.updated.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </span>
        )}
        <span class:list={["text-xs px-2 py-0.5 rounded font-medium", categoryColors[piece.data.category]]}>
          {piece.data.category}
        </span>
      </div>
      {piece.data.tags.length > 0 && (
        <div class="flex gap-2 mt-3">
          {piece.data.tags.map((tag) => (
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <Content />

    <CommitHistory commits={commits} filePath={filePath} />
  </article>

  <nav class="mt-12 pt-6 border-t border-gray-200 not-prose">
    <a href="/writing" class="text-sm text-gray-600 hover:text-gray-900">
      &larr; Back to Writing
    </a>
  </nav>
</BaseLayout>
