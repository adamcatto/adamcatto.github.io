---
import BaseLayout from "../layouts/BaseLayout.astro";
import MediaEmbed from "../components/MediaEmbed.astro";
import { getCollection } from "astro:content";
import { getProjectLinks, getPrimaryVideo, getShowcaseSlug } from "../lib/showcase";
import { resolveProjectVideo } from "../lib/contentVideos";

const projects = (await getCollection("projects")).sort(
  (a, b) => (b.data.priority ?? 0) - (a.data.priority ?? 0)
);
---

<BaseLayout title="Projects">
  <div class="prose">
    <h1>Projects</h1>

    <p>
      A selection of research and engineering projects I've worked on.
    </p>

    {projects.length === 0 ? (
      <p class="text-gray-500 italic mt-8">
        Projects coming soon.
      </p>
    ) : (
      <div class="grid gap-6 mt-8">
        {projects.map((project) => {
          const slug = getShowcaseSlug(project.id);
          const detailUrl = `/projects/${slug}`;
          const links = getProjectLinks(project.data);
          const previewVideo = getPrimaryVideo(project.data);
          const resolvedPreviewVideo = previewVideo
            ? resolveProjectVideo(slug, previewVideo)
            : undefined;

          return (
            <article class="border border-gray-200 rounded-lg overflow-hidden hover:border-gray-300 transition-colors">
              <a href={detailUrl} class="block not-prose">
                <MediaEmbed
                  title={project.data.title}
                  thumbnail={project.data.thumbnail}
                  video={resolvedPreviewVideo}
                />
              </a>
              <div class="p-5">
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1">
                    <h2 class="text-lg font-medium text-gray-900 mt-0 mb-1">
                      <a href={detailUrl} class="hover:text-blue-600">
                        {project.data.title}
                      </a>
                    </h2>
                    {project.data.description && (
                      <p class="text-gray-600 text-sm mb-3">{project.data.description}</p>
                    )}
                    {project.data.tags && project.data.tags.length > 0 && (
                      <div class="flex flex-wrap gap-2">
                        {project.data.tags.map((tag) => (
                          <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                    <a href={detailUrl} class="inline-block mt-3 text-sm text-blue-600 hover:text-blue-800">
                      View details &rarr;
                    </a>
                  </div>
                  <div class="flex gap-2 flex-shrink-0">
                    {links.map((link) => (
                      <a
                        href={link.href}
                        target="_blank"
                        rel="noopener"
                        class="text-gray-400 hover:text-gray-600"
                        title={link.title}
                      >
                        {link.label === "GitHub" ? (
                          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                          </svg>
                        ) : (
                          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                          </svg>
                        )}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    )}
  </div>
</BaseLayout>
