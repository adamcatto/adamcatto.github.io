---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const apps = (await getCollection("apps")).sort(
  (a, b) => (b.data.priority ?? 0) - (a.data.priority ?? 0)
);
---

<BaseLayout title="App Studio">
  <div class="prose">
    <h1>App Studio</h1>

    <p>
      Mobile and desktop applications I've built.
    </p>

    {apps.length === 0 ? (
      <p class="text-gray-500 italic mt-8">
        Apps coming soon.
      </p>
    ) : (
      <div class="grid gap-8 mt-8">
        {apps.map((app) => (
          <article class="border border-gray-200 rounded-lg overflow-hidden hover:border-gray-300 transition-colors">
            {/* Thumbnail or Video */}
            {(app.data.thumbnail || app.data.video) && (
              <div class="flex justify-center bg-gray-100 p-4">
                {app.data.video ? (
                  <div class="aspect-video w-full max-w-lg">
                    {app.data.video.includes("youtube.com") || app.data.video.includes("youtu.be") ? (
                      <iframe
                        src={app.data.video.replace("watch?v=", "embed/").replace("youtu.be/", "youtube.com/embed/")}
                        class="w-full h-full"
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen
                      />
                    ) : app.data.video.includes("vimeo.com") ? (
                      <iframe
                        src={app.data.video.replace("vimeo.com/", "player.vimeo.com/video/")}
                        class="w-full h-full"
                        frameborder="0"
                        allow="autoplay; fullscreen; picture-in-picture"
                        allowfullscreen
                      />
                    ) : (
                      <video
                        src={app.data.video}
                        class="w-full h-full object-contain"
                        controls
                        preload="metadata"
                      />
                    )}
                  </div>
                ) : app.data.thumbnail && (
                  <Image
                    src={app.data.thumbnail}
                    alt={`${app.data.title} screenshot`}
                    class="max-h-64 object-contain"
                  />
                )}
              </div>
            )}
            <div class="p-5">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-1">
                  <h2 class="text-lg font-medium text-gray-900 mt-0 mb-0">
                    {app.data.url ? (
                      <a href={app.data.url} target="_blank" rel="noopener" class="hover:text-blue-600">
                        {app.data.title}
                      </a>
                    ) : (
                      app.data.title
                    )}
                  </h2>
                  {app.data.price && (
                    <span class:list={[
                      "text-xs px-2 py-0.5 rounded font-medium",
                      app.data.price === "Free"
                        ? "bg-green-100 text-green-700"
                        : "bg-amber-100 text-amber-700"
                    ]}>
                      {app.data.price}
                    </span>
                  )}
                </div>
                {app.data.description && (
                  <p class="text-gray-600 text-sm mb-3">{app.data.description}</p>
                )}
                {app.data.platforms && app.data.platforms.length > 0 && (
                  <div class="flex flex-wrap gap-2 mb-3">
                    {app.data.platforms.map((platform) => (
                      <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded">
                        {platform}
                      </span>
                    ))}
                  </div>
                )}
                {app.data.tags && app.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {app.data.tags.map((tag) => (
                      <span class="text-xs bg-blue-50 text-blue-600 px-2 py-0.5 rounded">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
              <div class="flex gap-2 flex-shrink-0">
                {app.data.appStore && (
                  <a
                    href={app.data.appStore}
                    target="_blank"
                    rel="noopener"
                    class="text-gray-400 hover:text-gray-600"
                    title="Download on App Store"
                  >
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
                    </svg>
                  </a>
                )}
                {app.data.playStore && (
                  <a
                    href={app.data.playStore}
                    target="_blank"
                    rel="noopener"
                    class="text-gray-400 hover:text-gray-600"
                    title="Get it on Google Play"
                  >
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.6 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"/>
                    </svg>
                  </a>
                )}
                {app.data.macStore && (
                  <a
                    href={app.data.macStore}
                    target="_blank"
                    rel="noopener"
                    class="text-gray-400 hover:text-gray-600"
                    title="Download on Mac App Store"
                  >
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                    </svg>
                  </a>
                )}
                {app.data.windows && (
                  <a
                    href={app.data.windows}
                    target="_blank"
                    rel="noopener"
                    class="text-gray-400 hover:text-gray-600"
                    title="Download for Windows"
                  >
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M3,12V6.75L9,5.43V11.91L3,12M20,3V11.75L10,11.9V5.21L20,3M3,13L9,13.09V19.9L3,18.75V13M20,13.25V22L10,20.09V13.1L20,13.25Z"/>
                    </svg>
                  </a>
                )}
                {app.data.github && (
                  <a
                    href={app.data.github}
                    target="_blank"
                    rel="noopener"
                    class="text-gray-400 hover:text-gray-600"
                    title="View on GitHub"
                  >
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                  </a>
                )}
                {app.data.url && (
                  <a
                    href={app.data.url}
                    target="_blank"
                    rel="noopener"
                    class="text-gray-400 hover:text-gray-600"
                    title="Visit website"
                  >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </a>
                )}
              </div>
            </div>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
