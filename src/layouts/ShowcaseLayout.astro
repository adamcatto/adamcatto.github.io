---
import BaseLayout from "./BaseLayout.astro";
import MediaEmbed from "../components/MediaEmbed.astro";
import type { ImageMetadata } from "astro";
import type { ShowcaseLink, ShowcaseVideo } from "../lib/showcase";

interface Props {
  title: string;
  description?: string;
  tags?: string[];
  thumbnail?: ImageMetadata;
  video?: string;
  videos?: ShowcaseVideo[];
  language?: string;
  links?: ShowcaseLink[];
  backHref: string;
  backLabel: string;
}

const {
  title,
  description,
  tags = [],
  thumbnail,
  video,
  videos = [],
  language,
  links = [],
  backHref,
  backLabel,
} = Astro.props;

const mediaVideos =
  videos.length > 0 ? videos : video ? [{ src: video }] : [];
const showThumbnail = mediaVideos.length === 0 && thumbnail;
---

<BaseLayout title={title} description={description}>
  <article class="prose showcase-content">
    <header class="mb-8 not-prose">
      <h1 class="mb-2">{title}</h1>
      {description && <p class="text-lg text-gray-600 mb-4">{description}</p>}

      <div class="flex flex-wrap items-center gap-3 mb-4">
        {language && (
          <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded font-mono">
            {language}
          </span>
        )}
        {tags.map((tag) => (
          <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded">{tag}</span>
        ))}
      </div>

      {links.length > 0 && (
        <div class="flex flex-wrap gap-3">
          {links.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1 text-sm text-blue-600 hover:text-blue-800"
            >
              {link.label}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          ))}
        </div>
      )}
    </header>

    {mediaVideos.length > 0 && (
      <div class="mb-8 not-prose space-y-8">
        {mediaVideos.map((item) => (
          <MediaEmbed
            title={item.title ?? title}
            video={item.src}
            label={item.title}
            imageClass="w-full max-h-[32rem] object-contain bg-gray-50"
          />
        ))}
      </div>
    )}

    {showThumbnail && (
      <MediaEmbed
        title={title}
        thumbnail={thumbnail}
        class="mb-8 not-prose"
        imageClass="w-full max-h-[32rem] object-contain bg-gray-50"
      />
    )}

    <slot />

    <nav class="mt-12 pt-6 border-t border-gray-200 not-prose">
      <a href={backHref} class="text-sm text-gray-600 hover:text-gray-900">
        &larr; {backLabel}
      </a>
    </nav>
  </article>
</BaseLayout>

<style>
  .showcase-content {
    max-width: 100%;
  }
</style>
